# SearchOps — environment variables
# Copy to .env and fill in your values.
# Never commit .env to git.

# ── Required ──────────────────────────────────────────────────────────────────

# App auth (you choose these)
APP_PASSWORD=your-chosen-password
SESSION_SECRET=at-least-32-random-characters-choose-something-long

# ── LLM provider (pick one) ───────────────────────────────────────────────────

# Which provider to use as primary: gemini | anthropic | openai
LLM_PROVIDER=gemini

# Gemini (default; get key at https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=

# Anthropic Claude (get key at https://console.anthropic.com/)
ANTHROPIC_API_KEY=

# OpenAI (get key at https://platform.openai.com/)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=  # optional: override for LM Studio or other compatible APIs

# ── Gemini model overrides (optional) ─────────────────────────────────────────
# GEMINI_PRO_MODEL=gemini-2.5-flash
# GEMINI_FLASH_MODEL=gemini-2.5-flash

# ── Storage ───────────────────────────────────────────────────────────────────

# Local SQLite path (defaults to /data/recruiting.db for Modal; override for local dev)
DATABASE_PATH=recruiting.db

# ── Notifications (optional) ──────────────────────────────────────────────────

# Slack webhook URL — fires when a job scores ≥ 8
# Get at: Slack API → Your Apps → Incoming Webhooks
SLACK_WEBHOOK_URL=

# ── Google Sheets integration (optional) ──────────────────────────────────────
# If unset, the app runs entirely without Google. Add-by-URL is the default intake.
GOOGLE_SHEET_ID=
INTERVIEW_PREP_DOC_ID=

# ── Web scraping (optional) ───────────────────────────────────────────────────
# Jina AI — enhanced job description extraction
# JINA_API_KEY=

# Firecrawl — alternative scraper for complex ATS pages
# FIRECRAWL_API_KEY=
